# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Backend (optional - mock weather used if not set)
OPENWEATHER_API_KEY=

# Overpass API endpoint (optional - uses primary endpoint, falls back to public instances)
OVERPASS_API_URL=

# Google Gemini (optional - AI recommendations disabled if not set)
GEMINI_API_KEY=

# Gemini model name (optional - defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Frontend (optional - OSRM fallback used if not set)
VITE_ORS_API_KEY=
