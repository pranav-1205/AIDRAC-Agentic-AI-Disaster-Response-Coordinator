# PostgreSQL
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# Backend (optional - mock weather used if not set)
OPENWEATHER_API_KEY=

# Overpass API endpoint (optional - uses primary endpoint, falls back to public instances)
OVERPASS_API_URL=

# Google Gemini (optional - AI recommendations disabled if not set)
GEMINI_API_KEY=

# Gemini model name (optional - defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Frontend (optional - OSRM fallback used if not set)
VITE_ORS_API_KEY=

# IMD CAP RSS feed (primary official alert source for India)
IMD_CAP_RSS_URL=https://cap-sources.s3.amazonaws.com/in-imd-en/rss.xml

# NDMA CAP RSS feed (secondary official alert source — fetched concurrently and merged with IMD)
NDMA_CAP_RSS_URL=https://sachet.ndma.gov.in/cap_public_website/rss/rss_india.xml

# Background refresh interval in seconds (default 300 = 5 minutes)
REFRESH_INTERVAL_SECONDS=300

# Alert retention period in days (default 30)
ALERT_RETENTION_DAYS=30
